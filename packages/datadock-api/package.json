{
  "name": "@nowgai/datadock-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=node",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "supabase",
    "baas",
    "neon",
    "postgres",
    "api-gateway"
  ],
