{
  "name": "nowgai-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:web": "bun run --cwd packages/web dev",
    "dev:admin": "bun run --cwd packages/admin-client dev & bun run --cwd packages/admin-server dev",
    "dev:admin-client": "bun run --cwd packages/admin-client dev",
    "dev:admin-server": "bun run --cwd packages/admin-server dev",
    "dev:datadock": "bun run --cwd packages/datadock-api dev",
    "build": "bun run --filter '*' build",
    "build:shared": "bun run --cwd packages/shared build",
    "build:web": "bun run --cwd packages/web build",
    "build:admin-client": "bun run --cwd packages/admin-client build",
    "build:admin-server": "bun run --cwd packages/admin-server build",
    "build:datadock": "bun run --cwd packages/datadock-api build",
    "start:web": "bun run --cwd packages/web start",
    "start:admin-server": "bun run --cwd packages/admin-server start",
    "start:datadock": "bun run --cwd packages/datadock-api start",
    "typecheck": "bun run --filter '*' typecheck",
    "preinstall": "bun run build:shared || true"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
